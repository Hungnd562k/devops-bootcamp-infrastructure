pipeline {
    agent {
        docker {
            image 'node:18-alpine'
            label 'be'
            // Mount thư mục cache để npm install chạy nhanh hơn ở các lần sau
            args '-v /tmp/.npm-cache:/root/.npm'
        }
    }
    stages {
        stage('Checkout') {
            steps {
                git credentialsId: 'f50ff99b-330f-4bfb-8ad5-5953526e33b4', url: 'https://github.com/Hungnd562k/devops-bootcamp-todolist-backend-api.git', branch: 'master'
            }
        }
        stage('Build') {
            steps {
                sh '''
                    set -x
                    node -v
                    # Ghi toàn bộ log ra file /tmp/npm-build.log và vừa in ra màn hình
                    npm install --verbose 2>&1 | tee /tmp/npm-build.log
                    npm run build
                '''
            }
        }
        stage('Test') {
            steps {
                echo 'Test'
            }
        }
        stage('Quality gate') {
            steps {
                echo 'Quality gate'
            }
        }
    }
}